# ============================================================
# ArchivaCloud P-12 — Variables de entorno
# Copia este archivo como ".env" y completa los valores reales.
# ¡NUNCA subas el archivo ".env" al repositorio!
# ============================================================

# ── AWS Credentials ──────────────────────────────────────────
# Obtenidas desde "AWS Details" en el Learner Lab de AWS Academy.
# Estas credenciales son TEMPORALES y caducan con la sesión.
AWS_ACCESS_KEY_ID=ASIA_TU_ACCESS_KEY_AQUI
AWS_SECRET_ACCESS_KEY=tu_secret_key_aqui
AWS_SESSION_TOKEN=tu_session_token_aqui

# ── S3 — Parámetros únicos P-12 (Anexo B) ────────────────────
AWS_REGION=us-east-2
S3_BUCKET_NAME=archivacloud-p12

# ── Backend ───────────────────────────────────────────────────
# URL del frontend (para CORS — SEC-02)
# En desarrollo local: http://localhost:5173
# En producción: reemplazar con el dominio real
FRONTEND_URL=http://localhost:5173
