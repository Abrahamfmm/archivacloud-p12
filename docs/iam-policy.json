{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ArchivaCloudP12MinimumPrivilege",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject",
        "s3:ListBucket",
        "s3:CopyObject"
      ],
      "Resource": [
        "arn:aws:s3:::archivacloud-p12",
        "arn:aws:s3:::archivacloud-p12/*"
      ]
    }
  ]
}